<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Загальне меню — Mini Pekarnya Pitsa Smayl</title>
  <meta name="description" content="Загальне меню Mini Pekarnya Pitsa Smayl — піца, випічка та напої. Вул. Героїв Дніпра, 41, Київ. Тел: 063 637 43 06." />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --terracotta: #C0522B; --orange: #E07B39; --orange-light: #F4A261;
      --cream: #FDF6EC; --cream-dark: #F5E6CC;
      --brown: #3D2008; --brown-mid: #6B3A1F;
      --text: #2D1A0E; --text-light: #7A5C44; --white: #FFFFFF;
      --shadow: rgba(61,32,8,.18);
      --font-accent: 'Pacifico', cursive;
      --font-body: 'Nunito', sans-serif;
      --radius: 16px; --transition: .3s ease;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); background: var(--cream); color: var(--text); line-height: 1.6; overflow-x: hidden; }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }

    /* ---- HEADER ---- */
    .site-header {
      position: sticky; top: 0; left: 0; width: 100%; z-index: 1000;
      padding: 10px 24px; display: flex; align-items: center; justify-content: space-between;
      background: rgba(253,246,236,.97); backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(192,82,43,.15);
      box-shadow: 0 4px 24px var(--shadow);
    }
    .nav-logo { display: flex; align-items: center; gap: 10px; position: relative; }
    .nav-logo-img { width: auto; height: 60px; object-fit: contain; flex-shrink: 0; transition: transform var(--transition); }
    .nav-logo:hover .nav-logo-img { transform: scale(1.08) rotate(5deg); }
    .nav-logo-text-img {
        position: absolute;
        left: 50px;
        top: 50%;
        transform: translateY(-42%);
        height: 120px;
        width: auto;
        max-width: none;
        object-fit: contain;
        pointer-events: none;
      }
    .nav-back {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-body); font-weight: 700; font-size: .9rem;
      color: var(--brown-mid); padding: 8px 18px; border-radius: 50px;
      border: 2px solid var(--cream-dark); background: var(--cream);
      transition: all var(--transition);
    }
    .nav-back:hover { background: var(--terracotta); color: var(--white); border-color: var(--terracotta); }
    .nav-back svg { width: 16px; height: 16px; flex-shrink: 0; }
    .nav-cta {
      background: var(--terracotta); color: var(--white); padding: 8px 18px;
      border-radius: 50px; font-size: .82rem; font-weight: 800;
      display: inline-flex; align-items: center; gap: 6px;
      transition: background var(--transition), transform var(--transition);
    }
    .nav-cta:hover { background: var(--brown-mid); transform: scale(1.04); }

    /* ---- MENU PAGE HERO ---- */
    .menu-page-hero {
      background: linear-gradient(135deg, var(--brown) 0%, var(--terracotta) 60%, var(--orange) 100%);
      padding: 56px 24px 48px;
      text-align: center;
    }
    .menu-page-hero .section-label {
      display: inline-block; font-size: .72rem; font-weight: 800;
      letter-spacing: .18em; text-transform: uppercase;
      color: rgba(255,255,255,.7); margin-bottom: 10px;
    }
    .menu-page-hero h1 {
      font-family: var(--font-accent);
      font-size: clamp(2.5rem, 6vw, 4rem);
      color: var(--white);
      text-shadow: 0 4px 20px rgba(0,0,0,.4);
      line-height: 1.15;
    }

    /* ---- MENU CONTENT ---- */
    .menu-content { padding: 50px 20px 80px; }
    .container { max-width: 1160px; margin: 0 auto; }

    .menu-tabs { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; margin-bottom: 40px; }
    .tab-btn {
      padding: 9px 22px; border-radius: 50px; border: 2px solid var(--cream-dark);
      background: var(--cream); color: var(--text-light);
      font-family: var(--font-body); font-weight: 700; font-size: .88rem;
      cursor: pointer; transition: all var(--transition);
    }
    .tab-btn:hover, .tab-btn.active {
      background: var(--terracotta); color: var(--white); border-color: var(--terracotta);
    }

    .menu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
    .menu-card { background: var(--white);  border-radius: var(--radius); overflow: hidden;
      box-shadow: 0 4px 20px rgba(61,32,8,.09);
      transition: transform var(--transition), box-shadow var(--transition);
      display: flex; flex-direction: column;
    }
    .menu-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(61,32,8,.16); }
    .menu-card-img { height: 200px; overflow: hidden; position: relative; background: #f0e0cc; }
    .menu-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
    .menu-card-img .ep { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
    .menu-card:hover .menu-card-img img { transform: scale(1.06); }
    .menu-card-badge {
      position: absolute; top: 12px; left: 12px;
      background: var(--terracotta); color: var(--white);
      font-size: .68rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: .07em; padding: 4px 10px; border-radius: 50px;
    }
    .menu-card-body { padding: 18px 20px 20px; flex: 1; display: flex; flex-direction: column; }
    .menu-card-title { font-family: var(--font-accent); font-size: 1.22rem; color: var(--brown); margin-bottom: 6px; }
    .menu-card-desc { font-size: .85rem; color: var(--text-light); flex: 1; margin-bottom: 14px; line-height: 1.5; }
    .menu-card-footer { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .menu-card-price { font-family: var(--font-accent); font-size: 1.4rem; color: var(--terracotta); }
    .menu-card-size { font-size: .75rem; color: var(--text-light); font-weight: 600; }

    /* ---- FOOTER ---- */
    .footer-bar {
      background: linear-gradient(135deg, var(--brown) 0%, var(--brown-mid) 100%);
      text-align: center; padding: 24px 20px;
      font-size: .82rem; color: rgba(255,255,255,.6);
    }
    .footer-bar a { color: rgba(255,255,255,.8); font-weight: 700; }
    .footer-bar a:hover { color: var(--white); }

    /* ---- STICKY CALL (mobile) ---- */
    .sticky-call {
      display: none; position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%);
      z-index: 999; background: var(--terracotta); color: var(--white);
      font-family: var(--font-body); font-weight: 800; font-size: 1rem;
      padding: 15px 36px; border-radius: 50px;
      box-shadow: 0 8px 32px rgba(192,82,43,.55);
      animation: pulseBtn 2.4s ease-in-out infinite;
      white-space: nowrap; align-items: center; gap: 8px;
    }
    @keyframes pulseBtn { 0%,100% { box-shadow: 0 8px 32px rgba(192,82,43,.55); } 50% { box-shadow: 0 8px 48px rgba(192,82,43,.85); } }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: .1s; }
    .reveal-delay-2 { transition-delay: .2s; }

    @media (max-width: 700px) {
      .menu-grid { grid-template-columns: 1fr; }
      .sticky-call { display: flex; }
      .nav-logo-text-img {
          position: absolute;
          left: 40px;
          top: 50%;
          transform: translateY(-42%);
          height: 60px;
          width: auto;
          max-width: none;
          object-fit: contain;
          pointer-events: none;
        }
      .nav-logo-img { height: 46px; }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="site-header" id="site-header">
    <a href="index.html" class="nav-logo" aria-label="Повернутись на головну">
      <img src="images/magnific_Uy1pWm4wny.png" class="nav-logo-img" alt="Логотип Smayl Pitsa" />
      <img src="images/magnific_1sunOfcr4r.png" class="nav-logo-text-img" alt="міні ПЕКАРНЯ" />
    </a>
    <div style="display:flex; align-items:center; gap:12px;">
      <a href="index.html" class="nav-back">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        На головну
      </a>
      <a href="tel:+380636374306" class="nav-cta">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="14" height="14"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        Зателефонувати
      </a>
    </div>
  </header>

  <!-- HERO BANNER -->
  <div class="menu-page-hero">
    <span class="section-label">Mini Pekarnya</span>
    <h1>Загальне меню</h1>
  </div>

  <!-- MENU -->
  <section class="menu-content" aria-label="Меню">
    <div class="container">

      
      
      <div class="menu-tabs" role="tablist" aria-label="Категорії меню">
        <button class="tab-btn active" data-category="all" role="tab" aria-selected="true" id="tab-all">Усі позиції</button>
        <button class="tab-btn" data-category="pizza" role="tab" aria-selected="false">Піца</button>
        <button class="tab-btn" data-category="sauces" role="tab" aria-selected="false">Соуси</button>
        <button class="tab-btn" data-category="cheese" role="tab" aria-selected="false">Сир</button>
        <button class="tab-btn" data-category="meat" role="tab" aria-selected="false">М'ясні продукти</button>
        <button class="tab-btn" data-category="veg" role="tab" aria-selected="false">Овочі та зелень</button>
      </div>

      <div class="menu-grid" id="menu-grid" role="list">

        <article class="menu-card reveal" data-category="pizza" role="listitem">
          <div class="menu-card-img">
            <img src="images/pizza_01_base.jpg" alt="Основа для піци" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;" />
          </div>
          <div class="menu-card-body">
            <h3 class="menu-card-title" style="font-family: var(--font-accent);">Основа для піци</h3>
            <p class="menu-card-desc">тісто без начинки</p>

            <div class="menu-card-footer" style="flex-direction:column; align-items:flex-start; gap:8px;">
              <div style="display:flex; justify-content:space-between; width:100%;">
                <span class="menu-card-size">200г</span>
                <span class="menu-card-price" style="font-size:1.1rem; font-weight:800;">25 ₴</span>
              </div>
              <div style="display:flex; justify-content:space-between; width:100%;">
                <span class="menu-card-size">400г</span>
                <span class="menu-card-price" style="font-size:1.1rem; font-weight:800;">50 ₴</span>
              </div>
