<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-Content-Type-Options" content="nosniff" />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self' https:; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; frame-src https://www.google.com; img-src 'self' data: https:;" />
  <title>Mini Pekarnya Pitsa Smayl — Піца та випічка у Києві, вул. Героїв Дніпра 41</title>
  <meta name="description" content="Mini Pekarnya Pitsa Smayl — затишна міні-пекарня та піцерія у Києві на вулиці Героїв Дніпра 41, 47. Смачна домашня піца, свіжа випічка, тепла атмосфера. Щодня 09:00–20:00. Тел: 063 637 43 06." />
  <meta name="keywords" content="піца Київ, піцерія Героїв Дніпра, міні пекарня Київ, Mini Pekarnya Pitsa Smayl, замовити піцу Київ" />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content="Mini Pekarnya Pitsa Smayl — Домашня піца у Києві" />
  <meta property="og:description" content="Затишна піцерія та міні-пекарня у Києві. Свіже тісто, домашні інгредієнти, тепла атмосфера. Вул. Героїв Дніпра 41." />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --terracotta: #C0522B; --orange: #E07B39; --orange-light: #F4A261;
      --cream: #FDF6EC; --cream-dark: #F5E6CC;
      --brown: #3D2008; --brown-mid: #6B3A1F;
      --text: #2D1A0E; --text-light: #7A5C44; --white: #FFFFFF;
      --shadow: rgba(61,32,8,.18);
      --font-accent: 'Pacifico', cursive;
      --font-body: 'Nunito', sans-serif;
      --section-pad: 80px 20px; --radius: 16px; --transition: .3s ease;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); background: var(--cream); color: var(--text); line-height: 1.6; overflow-x: hidden; }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }

    /* ---- HEADER ---- */
    .site-header {
      position: fixed; top: 0; left: 0; width: 100%; z-index: 1000;
      padding: 10px 24px; display: flex; align-items: center; justify-content: space-between;
      background: rgba(253,246,236,.93); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(192,82,43,.15); transition: box-shadow var(--transition);
    }
    .site-header.scrolled { box-shadow: 0 4px 24px var(--shadow); }

    /* === Fix #1: Logo clipped to circle + Fix #2: text as image === */
    .nav-logo {
        display: flex; align-items: center; gap: 10px; text-decoration: none; position: relative;
      }
    /* Updated logo style */
    .nav-logo-img {
      width: auto; 
      height: 60px;
      object-fit: contain;
      flex-shrink: 0;
      transition: transform var(--transition);
    }
    .nav-logo:hover .nav-logo-img { transform: scale(1.08) rotate(5deg); }

    /* Updated logo text style */
    .nav-logo-text-img {
        position: absolute;
        left: 50px;
        top: 50%;
        transform: translateY(-42%);
        height: 120px;
        width: auto;
        max-width: none;
        object-fit: contain;
        pointer-events: none;
      }

    .nav-links { display: flex; gap: 24px; list-style: none; align-items: center; }
    .nav-links a { font-size: .88rem; font-weight: 700; color: var(--brown-mid); transition: color var(--transition); position: relative; }
    .nav-links a::after { content: ''; position: absolute; bottom: -3px; left: 0; width: 0; height: 2px; background: var(--terracotta); transition: width var(--transition); border-radius: 2px; }
    .nav-links a:hover { color: var(--terracotta); }
    .nav-links a:hover::after { width: 100%; }
    .nav-cta { background: var(--terracotta) !important; color: var(--white) !important; padding: 8px 18px !important; border-radius: 50px; font-size: .82rem !important; display: inline-flex !important; align-items: center; gap: 6px; }
    .nav-cta::after { display: none !important; }
    .nav-cta:hover { background: var(--brown-mid) !important; transform: scale(1.04); }
    .nav-cta svg { flex-shrink: 0; }
    .burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; }
    .burger span { width: 26px; height: 2.5px; background: var(--brown); border-radius: 2px; display: block; transition: all .3s ease; }

    /* ---- HERO ---- */
    .hero { position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; overflow: hidden; background: #2d1408; }
    .hero-bg {
      position: absolute;
      top: -20%; left: 0; right: 0; bottom: -20%;
      background-image: url('images/pizza_hero.jpg');
      background-size: cover; background-position: center;
      transform: scale(1.0); transition: transform 6s ease-out;
      will-change: transform;
    }
    .hero-bg.loaded { transform: scale(1); }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(160deg, rgba(61,32,8,.72) 0%, rgba(192,82,43,.42) 50%, rgba(61,32,8,.78) 100%); }
    .hero-content { position: relative; z-index: 2; max-width: 740px; padding: 20px; animation: fadeInUp 1s ease both; }

    .hero-badge {
        display: inline-block;
        background: rgba(30, 10, 0, 0.72);
        border: 1.5px solid rgba(244,162,97,.7);
      color: #ffffff;
      font-size: .78rem; font-weight: 800; letter-spacing: .18em; 
      padding: 7px 20px; border-radius: 50px; margin-bottom: 16px;
      backdrop-filter: blur(8px);
    }

    .hero-title { color: #ffffff;
        font-family: 'Pacifico', cursive;
        font-size: clamp(3rem, 7vw, 5rem);
        text-shadow: 0px 4px 15px rgba(0,0,0,0.4);
        margin-bottom: 30px;
        line-height: 1.3;
      }

    .hero-slogan { font-size: clamp(1rem, 2.5vw, 1.25rem); color: rgba(255,255,255,.9); font-weight: 500; margin-bottom: 24px; text-shadow: 0 2px 8px rgba(0,0,0,.5); }
    .hero-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
    .scroll-hint { position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 6px; color: rgba(255,255,255,.7); font-size: .72rem; letter-spacing: .1em;  animation: bounce 2s infinite; z-index: 2; }
    .scroll-hint svg { width: 22px; height: 22px; }

    /* ---- BUTTONS ---- */
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; border-radius: 50px; font-family: var(--font-body); font-weight: 800; font-size: 1rem; cursor: pointer; transition: all var(--transition); border: none; white-space: nowrap; }
    .btn-primary { background: var(--terracotta); color: var(--white); box-shadow: 0 6px 24px rgba(192,82,43,.45); }
    .btn-primary:hover { background: #d95f2b; transform: translateY(-2px); box-shadow: 0 10px 32px rgba(192,82,43,.55); }
    .btn-secondary { background: rgba(255,255,255,.15); color: var(--white); border: 2px solid rgba(255,255,255,.65); backdrop-filter: blur(4px); }
    .btn-secondary:hover { background: rgba(255,255,255,.25); transform: translateY(-2px); }

    /* ---- SECTIONS ---- */
    .section { padding: var(--section-pad); }
    .section-label { display: inline-block; font-size: .72rem; font-weight: 800; letter-spacing: .18em;  color: var(--terracotta); margin-bottom: 10px; }
    .section-title { font-family: var(--font-accent); font-size: clamp(2rem, 5vw, 3rem); color: var(--brown); line-height: 1.2; margin-bottom: 14px; }
    .section-sub { font-size: 1.05rem; color: var(--text-light); max-width: 560px; }
    .container { max-width: 1160px; margin: 0 auto; }

    /* ---- ABOUT ---- */
    .about { background: var(--cream); }
    .about-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    .about-image-wrap {
      position: relative; display: flex; align-items: center; justify-content: center;
      min-height: 420px;
    }
    .about-store-img {
      width: 100%; max-width: 650px;
      object-fit: contain;
      filter: drop-shadow(-6px 14px 28px rgba(61,32,8,.45)) drop-shadow(4px 20px 40px rgba(61,32,8,.3));
      animation: floatUpDown 4s ease-in-out infinite;
    }
    @keyframes floatUpDown {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-20px); }
    }
    .about-text p { color: var(--text-light); margin-bottom: 20px; font-size: 1.02rem; }
    .about-features { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-top: 32px; }
    .feature-card { background: var(--cream-dark); border-radius: 14px; padding: 20px 14px; text-align: center; transition: transform var(--transition), box-shadow var(--transition); }
    .feature-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px var(--shadow); }
    .feature-icon { margin-bottom: 10px; display: flex; align-items: center; justify-content: center; }
    .feature-icon svg { width: 36px; height: 36px; }
    .feature-card h4 { font-size: .82rem; font-weight: 800; color: var(--brown);  letter-spacing: .05em; }

    /* ---- MENU ---- */
    .menu-section { background: linear-gradient(180deg, var(--cream-dark) 0%, var(--cream) 100%); }
    .menu-header { text-align: center; margin-bottom: 50px; }
    .menu-tabs { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; margin-bottom: 40px; }
    .tab-btn { padding: 9px 22px; border-radius: 50px; border: 2px solid var(--cream-dark); background: var(--cream); color: var(--text-light); font-family: var(--font-body); font-weight: 700; font-size: .88rem; cursor: pointer; transition: all var(--transition); display: inline-flex; align-items: center; gap: 6px; }
    .tab-btn svg { width: 16px; height: 16px; flex-shrink: 0; }
    .tab-btn:hover, .tab-btn.active { background: var(--terracotta); color: var(--white); border-color: var(--terracotta); }
    .menu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
    .menu-card { background: var(--white);  border-radius: var(--radius); overflow: hidden; box-shadow: 0 4px 20px rgba(61,32,8,.09); transition: transform var(--transition), box-shadow var(--transition); display: flex; flex-direction: column; }
    .menu-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(61,32,8,.16); }
    .menu-card-img { height: 200px; overflow: hidden; position: relative; background: #f0e0cc; }
    .menu-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
    .menu-card-img .ep { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
    .menu-card:hover .menu-card-img img { transform: scale(1.06); }
    .menu-card-badge { position: absolute; top: 12px; left: 12px; background: var(--terracotta); color: var(--white); font-size: .68rem; font-weight: 800;  letter-spacing: .07em; padding: 4px 10px; border-radius: 50px; }
    .menu-card-body { padding: 18px 20px 20px; flex: 1; display: flex; flex-direction: column; }
    .menu-card-title { font-family: var(--font-accent); font-size: 1.22rem; color: var(--brown); margin-bottom: 6px; }
    .menu-card-desc { font-size: .85rem; color: var(--text-light); flex: 1; margin-bottom: 14px; line-height: 1.5; }
    .menu-card-footer { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .menu-card-price { font-family: var(--font-accent); font-size: 1.4rem; color: var(--terracotta); }
    .menu-card-size { font-size: .75rem; color: var(--text-light); font-weight: 600; }
    .menu-note { font-size: .82rem; color: var(--text-light); font-style: italic; background: rgba(192,82,43,.06); border: 1px dashed rgba(192,82,43,.25); border-radius: 10px; padding: 12px 20px; display: inline-block; }

    /* ---- GALLERY ---- */
    .gallery-section { background: var(--cream); }
    .gallery-header { text-align: center; margin-bottom: 40px; }
    .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); grid-template-rows: 260px 260px; gap: 16px; }
    .gallery-item { border-radius: 14px; overflow: hidden; box-shadow: 0 6px 24px var(--shadow); position: relative; cursor: pointer; }
    .gallery-item:nth-child(1) { grid-column: 1/2; grid-row: 1/3; }
    .gallery-item:nth-child(2) { grid-column: 2/3; grid-row: 1/2; }
    .gallery-item:nth-child(3) { grid-column: 3/4; grid-row: 1/2; }
    .gallery-item:nth-child(4) { grid-column: 2/3; grid-row: 2/3; }
    .gallery-item:nth-child(5) { grid-column: 3/4; grid-row: 2/3; }
    .gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
    .gallery-item:hover img { transform: scale(1.07); }
    .gallery-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(61,32,8,.5) 0%, transparent 60%); opacity: 0; transition: opacity var(--transition); }
    .gallery-item:hover .gallery-overlay { opacity: 1; }

    /* ---- CONTACTS: terracotta/orange theme ---- */
    .contacts-section {
      background: #c0522b;
      color: var(--cream); padding: 80px 20px 0;
    }
    .contacts-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
    .contacts-info .section-label { color: rgba(255,255,255,.7); }
    .contacts-info .section-title { color: var(--white); }
    .contact-block { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 28px; }
    .contact-icon {
      width: 52px; height: 52px;
      background: rgba(255,255,255,.18);
      border: 1.5px solid #ffffff;
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .contact-icon svg { width: 24px; height: 24px; fill: white; }
    .contact-details { flex: 1; }
    .contact-details h4 { font-size: .78rem;  letter-spacing: .1em; color: rgba(255,255,255,.75); font-weight: 700; margin-bottom: 4px; }
    .contact-details p, .contact-details a { font-size: 1.02rem; color: rgba(255,255,255,.95); font-weight: 600; }
    .contact-phone-big { display: inline-block; font-family: var(--font-accent); font-size: 1.8rem; color: var(--white); transition: color var(--transition); text-shadow: 0 2px 8px rgba(0,0,0,.2); }
    .contact-phone-big:hover { color: var(--cream-dark); }
    .map-container { border-radius: var(--radius); overflow: hidden; box-shadow: 0 8px 40px rgba(0,0,0,.3); height: 360px; }
    .map-container iframe { width: 100%; height: 100%; border: 0; }
    .footer-bar { background: rgba(0,0,0,.2); text-align: center; padding: 20px; margin-top: 60px; font-size: .8rem; color: rgba(255,255,255,.55); }

    /* ---- STICKY CALL ---- */
    .sticky-call { display: none; position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%); z-index: 999; background: var(--terracotta); color: var(--white); font-family: var(--font-body); font-weight: 800; font-size: 1rem; padding: 15px 36px; border-radius: 50px; box-shadow: 0 8px 32px rgba(192,82,43,.55); animation: pulseBtn 2.4s ease-in-out infinite; white-space: nowrap; align-items: center; gap: 8px; }    /* Contact phone big also has text-shadow which conflicts; override cleanly */
    .contact-phone-big {
    }

    /* ---- ANIMATIONS ---- */
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(32px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes bounce { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(8px); } }
    @keyframes pulseBtn { 0%,100% { box-shadow: 0 8px 32px rgba(192,82,43,.55); } 50% { box-shadow: 0 8px 48px rgba(192,82,43,.85); } }
    .reveal { opacity: 0; transform: translateY(36px); transition: opacity .7s ease, transform .7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: .1s; }
    .reveal-delay-2 { transition-delay: .2s; }
    .reveal-delay-3 { transition-delay: .3s; }
    .reveal-delay-4 { transition-delay: .4s; }

    /* ---- RESPONSIVE ---- */
    @media (max-width: 900px) {
      .about-inner { grid-template-columns: 1fr; gap: 36px; }
      .contacts-inner { grid-template-columns: 1fr; gap: 40px; }
      .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: 200px 200px 200px; }
      .gallery-item:nth-child(1) { grid-column: 1/3; grid-row: 1/2; }
      .gallery-item:nth-child(2) { grid-column: 1/2; grid-row: 2/3; }
      .gallery-item:nth-child(3) { grid-column: 2/3; grid-row: 2/3; }
      .gallery-item:nth-child(4) { grid-column: 1/2; grid-row: 3/4; }
      .gallery-item:nth-child(5) { grid-column: 2/3; grid-row: 3/4; }
    }
    @media (max-width: 700px) {
      :root { --section-pad: 60px 16px; }
      .nav-logo-img { width: 42px; height: 42px; }
      .nav-logo-text-img {
          position: absolute;
          left: 40px;
          top: 50%;
          transform: translateY(-42%);
          height: 60px;
          width: auto;
          max-width: none;
          object-fit: contain;
          pointer-events: none;
        }
      .nav-links { display: none; }
      .nav-links.open { display: flex; flex-direction: column; position: fixed; inset: 0; background: rgba(253,246,236,.97); justify-content: center; align-items: center; gap: 32px; backdrop-filter: blur(10px); z-index: 999; }
      .nav-links.open a { font-size: 1.3rem; }
      .burger { display: flex; z-index: 1001; }
      .burger.open span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
      .burger.open span:nth-child(2) { opacity: 0; }
      .burger.open span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
      .about-features { grid-template-columns: 1fr; }
      .menu-grid { grid-template-columns: 1fr; }
      .gallery-grid { grid-template-columns: 1fr; grid-template-rows: unset; }
      .gallery-item:nth-child(n) { grid-column: unset; grid-row: unset; height: 220px; }
      .sticky-call { display: flex; }
      .hero-actions .btn-secondary { display: none; }
      .hero-title { color: #ffffff; font-size: clamp(3rem, 13vw, 5rem); }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="site-header" id="site-header">
    <!--
      Fix #1: logo image clipped to circle via clip-path (removes cream bg)
      Fix #2: "міні ПЕКАРНЯ" as generated image with matching letterforms
    -->
    <a href="#hero" class="nav-logo" aria-label="Mini Pekarnya Pitsa Smayl — головна">
      <img
        src="images/magnific_Uy1pWm4wny.png"
        class="nav-logo-img"
        alt="Логотип Smayl Pitsa"
      />
      <img
        src="images/magnific_1sunOfcr4r.png"
        class="nav-logo-text-img"
        alt="міні ПЕКАРНЯ"
      />
    </a>
    <nav aria-label="Основна навігація">
      <ul class="nav-links" id="nav-links" role="menubar">
        <li><a href="#about" role="menuitem">Про нас</a></li>
        <li><a href="menu.html" role="menuitem">Меню</a></li>
        <li><a href="#gallery" role="menuitem">Галерея</a></li>
        <li><a href="#contacts" role="menuitem">Контакти</a></li>
        <li>
          <a href="tel:+380636374306" class="nav-cta" role="menuitem" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="14" height="14" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
            Зателефонувати
          </a>
        </li>
      </ul>
    </nav>
    <button class="burger" id="burger" aria-label="Відкрити меню" aria-expanded="false" aria-controls="nav-links">
      <span></span><span></span><span></span>
    </button>
  </header>

  <!-- HERO -->
  <section class="hero" id="hero" aria-label="Головний банер">
    <div class="hero-bg" id="hero-bg" role="img" aria-label="Апетитна піца від Mini Pekarnya Pitsa Smayl"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">

      <div class="hero-badge">Піца &middot; Випічка &middot; Київ</div>

      <h1 class="hero-title">міні Пекарня</h1>

      <p class="hero-slogan">
        Домашня піца з посмішкою —<br/>
        свіже тісто, щирі інгредієнти, тепла атмосфера
      </p>
      <div class="hero-actions">
        <a href="tel:+380636374306" class="btn btn-primary" id="hero-call-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          Зателефонувати
        </a>
        <a href="menu.html" class="btn btn-secondary">
          Переглянути меню
